# ============================================================
#  IBM Watsonx.ai — Nutrition Agent Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your .env file to version control.

# ---------------------------
# IBM Cloud / Watsonx.ai
# ---------------------------
IBM_API_KEY=2QZc74yWeyHXxFGXagYZs-ii8BX_w4Jdb2dQUwIPuEaa
WATSONX_PROJECT_ID=7503d311-99d4-478c-a507-90efeaeafd78
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ---------------------------
# Model Selection
# ---------------------------
# Available Granite models:
#   ibm/granite-3-3-8b-instruct  (default, fast)
#   ibm/granite-3-8b-instruct
#   ibm/granite-3-2b-instruct    (lightweight)
WATSONX_MODEL_ID=ibm/granite-3-3-8b-instruct

# ---------------------------
# Flask Configuration
# ---------------------------
FLASK_SECRET_KEY=change_this_to_a_random_secret_key_min_32_chars
FLASK_ENV=development
FLASK_PORT=5000
FLASK_DEBUG=True

# ---------------------------
# Agent Behavior Tuning
# ---------------------------
# Max tokens the model may generate per response
AGENT_MAX_TOKENS=1024
# Sampling temperature (0.0 = deterministic, 1.0 = creative)
AGENT_TEMPERATURE=0.7
# Top-p nucleus sampling
AGENT_TOP_P=0.9
